# ─────────────────────────────────────────
# PRAXIS AGENTS — Environment Variables
# ─────────────────────────────────────────

# Groq API Key (PRIMARY LLM — free at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Groq model to use — do NOT change this during the hackathon
GROQ_MODEL=llama-3.3-70b-versatile

# Tavily API Key (Literature QC search — free at app.tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here

# Google Gemini API Key (FALLBACK only — free at aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# ─────────────────────────────────────────
# OPTIONAL: Supabase (for feedback loop)
# Leave blank if not set up yet — agents work without it
# ─────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────
# AGENT CONFIG
# ─────────────────────────────────────────

# Max Tavily credits to use per full pipeline run (do not exceed 4)
TAVILY_MAX_CREDITS_PER_RUN=4

# Enable file-based cache for Tavily results (saves credits)
ENABLE_TAVILY_CACHE=true

# Enable console logging of full prompts (useful for debugging)
DEBUG_PROMPTS=false

