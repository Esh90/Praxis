# ─────────────────────────────────────────
# PRAXIS AGENTS — Environment Variables
# ─────────────────────────────────────────

# Groq API Key (PRIMARY LLM — free at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Single-model legacy override. If GROQ_MODEL_CANDIDATES is set, it wins.
GROQ_MODEL=llama-3.3-70b-versatile

# Comma-separated rotation list. Groq enforces token-per-day quotas PER MODEL,
# so listing multiple models effectively multiplies our daily budget without
# needing a second API key. groqClient.js tries them in order on 429 / 404.
GROQ_MODEL_CANDIDATES=llama-3.3-70b-versatile,llama-3.1-8b-instant,gemma2-9b-it,mixtral-8x7b-32768

# Tavily API Key (Literature QC search — free at app.tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here

# ─────────────────────────────────────────
# Gemini fallback (kicks in only after every Groq candidate is exhausted)
# Free at aistudio.google.com
# ─────────────────────────────────────────

GEMINI_API_KEY=your_gemini_api_key_here

# Comma-separated Gemini rotation. Smallest/fastest first since this is the
# fallback path. gemini-1.5-flash was retired from v1beta in 2026 — keep at
# the end of the list (or remove) and lean on the 2.x family.
GEMINI_MODEL_CANDIDATES=gemini-2.0-flash,gemini-2.0-flash-lite,gemini-2.0-flash-exp,gemini-1.5-flash-latest

# ─────────────────────────────────────────
# OPTIONAL: Supabase (for feedback loop + persistent RAG)
# Leave blank if not set up yet — agents work without it (local JSON cache
# in agents/cache/feedback_store.json takes over).
# ─────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────
# AGENT CONFIG
# ─────────────────────────────────────────

# Max Tavily credits to use per full pipeline run (do not exceed 4)
TAVILY_MAX_CREDITS_PER_RUN=4

# Enable file-based cache for Tavily results (saves credits across runs)
ENABLE_TAVILY_CACHE=true

# Enable console logging of full prompts (useful for debugging)
DEBUG_PROMPTS=false
