# ─────────────────────────────────────────────────────────────
# PRAXIS BACKEND — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy to backend/.env for local dev. On Render, set these in
# the service dashboard ("Environment" tab) instead — never commit secrets.

# ── Server ───────────────────────────────────────────────────
# Render sets PORT automatically — leave blank in production.
PORT=3002

# Comma-separated list of allowed frontend origins (production).
# Leave blank in local dev to allow any origin. Examples:
#   FRONTEND_ORIGIN=https://praxis.your-subdomain.workers.dev
#   FRONTEND_ORIGIN=https://praxis.example.com,https://www.praxis.example.com
FRONTEND_ORIGIN=

# Override the agents/ folder lookup if you self-host the agents elsewhere.
# Defaults to ../agents relative to the backend repo root.
# PRAXIS_AGENTS_ROOT=/opt/render/project/src/agents

# ── LLM keys (forwarded to the agents pipeline) ──────────────
# Required: at least GROQ_API_KEY. Tavily + Gemini are optional but recommended.
GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Multi-model rotation (Groq enforces per-model token quotas).
GROQ_MODEL_CANDIDATES=llama-3.3-70b-versatile,llama-3.1-8b-instant,gemma2-9b-it,mixtral-8x7b-32768
GEMINI_MODEL_CANDIDATES=gemini-2.0-flash,gemini-2.0-flash-lite,gemini-2.0-flash-exp

# ── Supabase (persistent feedback + RAG) ─────────────────────
# Service-role key is server-only — NEVER expose in the frontend.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Agents tuning (optional) ─────────────────────────────────
TAVILY_MAX_CREDITS_PER_RUN=4
ENABLE_TAVILY_CACHE=true
DEBUG_PROMPTS=false
