# ─────────────────────────────────────────────────────────────
# PRAXIS FRONTEND — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy to frontend/.env for local dev. For Cloudflare Workers, set these as
# Worker secrets (`npx wrangler secret put VAR_NAME`) or via the Cloudflare
# dashboard → Workers & Pages → your project → Settings → Variables.
#
# IMPORTANT: only variables prefixed VITE_ are inlined into the browser bundle.
# Never put server-only secrets (e.g. SUPABASE_SERVICE_ROLE_KEY) here.

# ── Backend API ──────────────────────────────────────────────
# In production, point this at your deployed backend, e.g.
#   VITE_PRAXIS_API_URL=https://praxis-backend.onrender.com
VITE_PRAXIS_API_URL=http://localhost:3002

# ── Supabase (browser-safe anon key only) ────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here
VITE_SUPABASE_PROJECT_ID=your_project_ref
